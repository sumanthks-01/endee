# Environment configuration — copy to .env and fill in values

# Endee server
ENDEE_URL=http://localhost:8080
ENDEE_AUTH_TOKEN=

# LLM backend: "ollama" (default, free) or "openai"
LLM_BACKEND=ollama
OLLAMA_MODEL=llama3.2

# Only needed when LLM_BACKEND=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
